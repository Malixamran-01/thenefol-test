# ============================================================
# BACKEND ENVIRONMENT — copy to .env and fill in your values
# ============================================================
# Sections:
#  1. Server & URLs
#  2. Database
#  3. Supabase
#  4. Security
#  5. Rate limiting & OTP
#  6. File uploads & image optimisation
#  7. Google OAuth
#  8. Razorpay
#  9. Email (SMTP)
# 10. SMS (Twilio)
# 11. Push notifications (Firebase)
# 12. WhatsApp Business Cloud API
# 13. Meta / Facebook (core + Ads + Graph + Instagram)
# 14. Amazon SP-API
# 15. Flipkart
# 16. Shiprocket
# 17. AI services
# 18. Analytics & pixels
# 19. Cloudflare Turnstile
# ============================================================


# ============================================================
# 1. SERVER & URLS
# ============================================================

PORT=2000
HOST=0.0.0.0

# The public hostname this backend is reachable at (used for redirect URIs etc.)
# Dev:  localhost
# Prod: thenefol.com
BACKEND_HOST=localhost
BACKEND_PORT=2000
BACKEND_URL=http://localhost:2000

# Admin credentials (used by reset-admin-credentials script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Admin User

# Frontend / CORS origins
# Dev:  http://localhost:2001
# Prod: https://thenefol.com
CLIENT_ORIGIN=http://localhost:2001
FRONTEND_URL=http://localhost:2001
USER_PANEL_URL=http://localhost:2001
ADMIN_PANEL_URL=http://localhost:5174


# ============================================================
# 2. DATABASE
# ============================================================
# Option A — Supabase Session Pooler (IPv4, recommended for cloud deploys)
DB_HOST=your-project-ref.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.your-project-ref
DB_PASSWORD=your_database_password
DB_NAME=postgres
DB_POOL_MODE=session
DATABASE_URL=postgresql://postgres.your-project-ref:your_database_password@your-project-ref.pooler.supabase.com:5432/postgres

# Set to 1 when connecting through Supabase pooler (enables pgbouncer-compatible mode)
USE_SUPABASE_DB=1

# Option B — Local / self-hosted Postgres
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/nefol
# DATABASE_PORT=5432


# ============================================================
# 3. SUPABASE API KEYS
# ============================================================
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# ============================================================
# 4. SECURITY
# ============================================================
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here


# ============================================================
# 5. RATE LIMITING & OTP
# ============================================================
# Requests per window (default: 100 000 req / 60 s — very permissive for dev)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100000

# OTP settings
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6
RATE_LIMIT_OTP_PER_HOUR=5


# ============================================================
# 6. FILE UPLOADS & IMAGE OPTIMISATION
# ============================================================
# Persist uploads OUTSIDE the deploy folder (required on Hostinger VPS).
# Default (dev, unset): <repo>/uploads-data next to backend/
# Production (uncomment on server):
# UPLOADS_DIR=/var/lib/nefol/uploads

MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# WebP conversion (all uploaded images are auto-converted to WebP).
# Lossy quality 1-100 (default 82). Set WEBP_LOSSLESS=1 for lossless mode.
WEBP_QUALITY=82
WEBP_LOSSLESS=0


# ============================================================
# 7. GOOGLE OAUTH
# ============================================================
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Add your domain to "Authorised JavaScript origins".
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret


# ============================================================
# 8. RAZORPAY
# ============================================================
# Get from: https://dashboard.razorpay.com/ → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# ============================================================
# 9. EMAIL (Hostinger SMTP / any SMTP)
# ============================================================
EMAIL_USER=support@thenefol.com
EMAIL_PASS=your_email_password


# ============================================================
# 10. SMS — TWILIO
# ============================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number


# ============================================================
# 11. PUSH NOTIFICATIONS — FIREBASE
# ============================================================
FIREBASE_SERVER_KEY=your_firebase_server_key
FCM_PROJECT_ID=your_fcm_project_id


# ============================================================
# 12. WHATSAPP BUSINESS CLOUD API
# ============================================================
# Get from: Meta Business Manager → WhatsApp → API Setup

# Access token (WHATSAPP_TOKEN and WHATSAPP_ACCESS_TOKEN are interchangeable)
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Phone Number ID  (Meta Business Manager → WhatsApp → API Setup)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Business Account ID (optional, for advanced features)
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id

# Sender number: country code + digits, no + or spaces (e.g. 918887847213)
WHATSAPP_SENDER=918887847213

# Webhook verification token — generate any random string and paste the same
# value in Meta Business Manager → Webhooks → Verify Token
WHATSAPP_VERIFY_TOKEN=your_random_webhook_verify_token

# API base URL (usually v17.0 or later)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0

# App secret for webhook signature verification (Meta App Dashboard → Settings → Basic)
WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# Publicly accessible HTTPS URL where Meta sends webhook events
WHATSAPP_WEBHOOK_URL=https://thenefol.com/api/whatsapp/webhook

# Message templates (must be approved in Meta Business Manager)
WHATSAPP_USE_TEMPLATE=true
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
WHATSAPP_TEMPLATE_HAS_CONTACT=true
WHATSAPP_CONTACT_INFO=918887847213
WHATSAPP_TEMPLATE_HAS_BUTTON=true

# Button URL: plain domain only — no https://, no trailing slash (max 15 chars)
WHATSAPP_BUTTON_URL=thenefol.com

# Optional META_WA_* aliases (take precedence over WHATSAPP_* when set)
# META_WA_TOKEN=
# META_WA_NUMBER_ID=
# META_WA_PHONE_NUMBER=
# META_WA_API_URL=
# META_WA_VERIFY_TOKEN=


# ============================================================
# 13. META / FACEBOOK
# ============================================================
# Three separate Meta apps are used — keep their IDs/secrets distinct.
#
# App A: META_APP_ID / META_APP_SECRET
#   Original / legacy app (WhatsApp Business, old integrations).
#   Leave as-is if you already have it set.
META_APP_ID=your_legacy_meta_app_id
META_APP_SECRET=your_legacy_meta_app_secret
#
# App B: META_GRAPH_APP_ID / META_GRAPH_APP_SECRET
#   Graph API / Instagram OAuth / Collab flows.
#   Fallback chain in code: INSTAGRAM_APP_ID → META_GRAPH_APP_ID → META_APP_ID
META_GRAPH_APP_ID=your_graph_instagram_collab_app_id
META_GRAPH_APP_SECRET=your_graph_instagram_collab_app_secret
#
# App C: META_ADS_APP_ID / META_ADS_APP_SECRET
#   Marketing / Ads API (see src/config/metaAdsEnv.ts).
#   Fallback chain: META_ADS_APP_ID → META_GRAPH_APP_ID → META_APP_ID
META_ADS_APP_ID=your_ads_app_id
META_ADS_APP_SECRET=your_ads_app_secret

# Set to 1 to force backend to read tokens from .env instead of the database
META_USE_ENV_ONLY=1

# Long-lived Graph / Page access tokens
# Get from: Meta Graph API Explorer → Generate Token
META_GRAPH_ACCESS_TOKEN=your_graph_access_token
META_PAGE_ACCESS_TOKEN=your_page_access_token

# Ad account, Facebook Page, and Pixel
# META_AD_ACCOUNT_ID format: act_<number>
META_AD_ACCOUNT_ID=act_your_ad_account_id
META_FB_PAGE_ID=your_facebook_page_id
META_ADS_PIXEL_ID=your_pixel_id

# Business App (optional — only needed for Business API features)
META_BUSINESS_APP_ID=
META_BUSINESS_APP_SECRET=

# Instagram Product App (Meta Dev Console → your app → Instagram → API Setup)
# May differ from META_GRAPH_APP_ID if you have a separate Instagram product app
INSTAGRAM_APP_ID=your_instagram_product_app_id
INSTAGRAM_APP_SECRET=your_instagram_product_app_secret

# Legacy/static Instagram access token (optional — used for read-only feed display)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# Legacy social placeholders (update when you enable these integrations)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret


# ============================================================
# 14. AMAZON SP-API
# ============================================================
# LWA (Login with Amazon) app credentials
# Register at: https://sellercentral.amazon.in → Apps & Services → Develop Apps
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.your_client_id
AMAZON_LWA_CLIENT_SECRET=amzn1.oa2-cs.v1.your_client_secret

# Redirect URI — must match what is registered in your LWA app exactly.
# Dev:  https://thenefol-test-1.onrender.com/api/amazon/oauth/callback
# Prod: https://thenefol.com/api/amazon/oauth/callback
AMAZON_OAUTH_REDIRECT_URI=https://thenefol.com/api/amazon/oauth/callback

# Refresh token — paste here after completing OAuth, or let the /api/amazon/oauth/callback flow store it.
AMAZON_SP_API_REFRESH_TOKEN=

# Marketplace ID. Default: India (A21TJRUUN4KGV). US: ATVPDKIKX0DER
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# SP-API region group: eu | na | fe  (India = eu)
AMAZON_SP_API_REGION=eu

# Unified sales sync settings
AMAZON_UNIFIED_SALES_LOOKBACK_DAYS=365
AMAZON_UNIFIED_SALES_FETCH_BUYER_INFO=1
AMAZON_UNIFIED_SALES_FULL_SYNC=1
AMAZON_UNIFIED_SALES_FETCH_ADDRESS=1

# Optional tuning (uncomment to override defaults)
# AMAZON_ORDER_API_DELAY_MS=200
# AMAZON_SP_API_DEBUG=1
# AMAZON_INVOICING_REPORT_SYNC=0
# AMAZON_INVOICING_REPORT_TYPES=GET_GST_MTR_B2B_CUSTOM,GET_GST_MTR_B2C_CUSTOM
# AMAZON_INVOICE_REPORT_LOOKBACK_DAYS=30
# AMAZON_INVOICE_REPORT_POLL_MS=10000
# AMAZON_INVOICING_REPORT_EU_MFN=0


# ============================================================
# 15. FLIPKART
# ============================================================
# App ID + Secret from Seller Hub → Developer → My Apps (not your seller login)
FLIPKART_SALES_API_KEY=your_flipkart_app_id
FLIPKART_SALES_SECRET=your_flipkart_app_secret

# API base: production or sandbox
# FLIPKART_API_BASE_URL=https://api.flipkart.net
# FLIPKART_API_BASE_URL=https://sandbox-api.flipkart.net

# Optional tuning
# FLIPKART_OAUTH_SCOPE=Seller_Api,Default
# FLIPKART_UNIFIED_SALES_SYNC=1
# FLIPKART_UNIFIED_SALES_LOOKBACK_DAYS=90
# FLIPKART_UNIFIED_SALES_FULL_SYNC=1
# FLIPKART_API_DEBUG=1


# ============================================================
# 16. SHIPROCKET
# ============================================================
# Get credentials from: https://app.shiprocket.in/
# Can also be configured via /api/shiprocket/config (admin panel) or the
# save-shiprocket-credentials.js script (which stores them in the database).
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password


# ============================================================
# 17. AI SERVICES
# ============================================================
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key


# ============================================================
# 18. ANALYTICS & PIXELS
# ============================================================
GOOGLE_ANALYTICS_ID=your_google_analytics_id
FACEBOOK_PIXEL_ID=your_facebook_pixel_id


# ============================================================
# 19. CLOUDFLARE TURNSTILE (Creator Collab apply form)
# ============================================================
# Create a widget at: https://dash.cloudflare.com/ → Turnstile
# Also set VITE_TURNSTILE_SITE_KEY in the user-panel .env
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
