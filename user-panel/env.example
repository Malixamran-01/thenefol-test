# Environment Configuration for Nefol User Panel
#
# Copy to ".env" in this folder — Vite only loads ".env" / ".env.local", NOT "env.example".
# After changing VITE_* vars, restart "npm run dev" or rebuild for production.

# API Configuration
# Note: In production, these are not needed as the app uses runtime detection
# These are only for development/testing purposes
VITE_API_URL=https://thenefol.com/api
VITE_API_HOST=thenefol.com
VITE_API_PORT=443
VITE_BACKEND_HOST=thenefol.com
VITE_BACKEND_PORT=443

# Frontend Configuration
VITE_USER_PANEL_PORT=443
VITE_ADMIN_PANEL_PORT=443

# App Configuration
VITE_APP_NAME=Nefol User Panel
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

VITE_TURNSTILE_SITE_KEY=0x4AAAAAACzXmH-bP3_CScSf
