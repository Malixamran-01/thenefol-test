{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/blog/:id",
      "destination": "https://nefolbackend-production.up.railway.app/blog/:id"
    },
    {
      "source": "/product/:slug",
      "destination": "https://nefolbackend-production.up.railway.app/product/:slug"
    },
    {
      "source": "/author/:id",
      "destination": "https://nefolbackend-production.up.railway.app/author/:id"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://nefolbackend-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!assets/|IMAGES/|favicon\\.svg|manifest\\.json|sw\\.js|light-mode-boot\\.js|vendor/|filerobot-editor/).*)",
      "destination": "/index.html"
    }
  ]
}
